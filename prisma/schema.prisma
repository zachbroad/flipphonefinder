generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Phone {
  name                String?
  brand               String?
  link                String?
  price               String?
  // featured            Boolean? @default(false)
  support_and_updates String?
  category            String?
  network             String?
  G_4G_3G_2G          String? @map("5G/4G/3G/2G")
  volte               String?
  rideshare           String?
  gps_navigation      String?
  shape               String?
  group_text_mms      String?
  removable_battery   String?
  operating_system    String?
  hotspot_tethering   String?
  browser             String?
  wifi_calling        String?
  whatsapp            String?
  sd_cards            String?
  FA                  String? @map("2FA")
  spotify             String?
  email               String?
  voice_to_text       String?
  t9_keyboard         String?
  usb_type            String?
  headphone_jack      String?
  signal_app          String?
  camera              String?
  calendar            String?
  screen_size_inches  String?
  screen_type         String?
  sim_type            String?
  sold_unlocked       String?
  dual_sim            String?
  podcasts_music      String?
  rugged              String?
  bluetooth           String?
  image               String?
  europe_network      String?
  touchscreen         String?
  android_auto        String?
  region              String?
  asia_network        String?
  nfc_support         String?
  esim                String?
  rating              Float?
  id                  Int     @id(map: "dump_pk") @default(autoincrement())

  @@index([id], map: "dump_id_index")
  @@map("phone")
}
